# Base ignore
.DS_Store
Thumbs.db
*.log
.vscode/
.idea/

# Backend
backend/vendor/
backend/node_modules/
backend/.env
backend/storage/framework/cache/*
backend/storage/framework/views/*
backend/storage/logs/*
backend/storage/*.key
/backend/public/storage
/backend/storage/app/public

# Laravel API
api/vendor/
api/node_modules/
api/.env
api/bootstrap/cache/*.php
!api/bootstrap/cache/.gitignore
api/storage/framework/cache/*
!api/storage/framework/cache/.gitignore
api/storage/framework/sessions/*
!api/storage/framework/sessions/.gitignore
api/storage/framework/views/*
!api/storage/framework/views/.gitignore
api/storage/logs/*
!api/storage/logs/.gitignore
api/storage/*.key
/api/public/storage
/api/storage/app/public

# Frontend
frontend/node_modules/
frontend/dist/
frontend/.env
frontend/.env.local
frontend/.env.*.local
frontend/.vite/

# Landing
landing/node_modules/
landing/dist/
landing/.env
landing/.env.local
landing/.env.*.local
landing/.vite/

# Temporary & Diagnostic
restructure_temp/
recovery_temp/
*.zip
*.sql
!database/schema/*.sql
backup_crm_stable_zip/
unused files/
backend/Unused files/
