use Illuminate\Http\Request;

define('LARAVEL_START', microtime(true));

/*
|--------------------------------------------------------------------------
| HOSTINGER DEPLOYMENT CONFIGURATION
|--------------------------------------------------------------------------
|
| This index.php file is configured for Hostinger shared hosting.
| The Laravel application core is located outside the public_html directory
| for security reasons.
