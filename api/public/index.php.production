|
*/

// Determine if the application is in maintenance mode...
if (file_exists($maintenance = __DIR__.'/../doctor_crm/storage/framework/maintenance.php')) {
    require $maintenance;
}

// Register the Composer autoloader...
require __DIR__.'/../doctor_crm/vendor/autoload.php';

// Bootstrap Laravel and handle the request...
(require_once __DIR__.'/../doctor_crm/bootstrap/app.php')
    ->handleRequest(Request::capture());
